<!DOCTYPE html>
<html lang="ky">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>KEPKA_KG | Премиум Баш Кийимдер</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,900&family=Inter:wght@200;400;600;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        :root {
            --bg: #030303; --text: #ffffff; --primary: #00f2ff;
            --card: rgba(255, 255, 255, 0.05);
            --border: rgba(255, 255, 255, 0.1); 
            --nav-bg: rgba(0, 0, 0, 0.95);
            --glow: 0 0 25px rgba(0, 242, 255, 0.3);
            --subtext: rgba(255, 255, 255, 0.5);
        }

        .light-mode {
            --bg: #fdfdfd; --text: #1a1a1a; --primary: #0072ff;
            --card: #ffffff; --border: rgba(0, 0, 0, 0.08); 
            --nav-bg: rgba(255, 255, 255, 0.98);
            --glow: 0 10px 30px rgba(0, 114, 255, 0.15);
            --subtext: rgba(0, 0, 0, 0.6);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        html { scroll-behavior: smooth; }
        body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; overflow-x: hidden; width: 100%; }
        h1, h2, h3, .logo { font-family: 'Playfair Display', serif; }

        /* --- НАВИГАЦИЯ & БУРГЕР --- */
        nav {
            position: fixed; top: 0; width: 100%; padding: 15px 5%;
            display: flex; justify-content: space-between; align-items: center;
            background: var(--nav-bg); backdrop-filter: blur(20px);
            z-index: 10000; border-bottom: 1px solid var(--border);
        }
        .logo { font-size: 1.8rem; font-weight: 900; letter-spacing: -1px; z-index: 10001; }
        .logo span { color: var(--primary); text-shadow: var(--glow); }

        .nav-links { display: flex; gap: 25px; align-items: center; }
        .nav-links a { color: var(--text); text-decoration: none; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; }

        .burger { display: none; cursor: pointer; flex-direction: column; gap: 6px; z-index: 10001; }
        .burger span { width: 30px; height: 3px; background: var(--text); border-radius: 10px; transition: 0.4s; }

        @media (max-width: 900px) {
            .nav-links { 
                position: fixed; top: 0; right: -100%; width: 80%; height: 100vh; 
                background: var(--bg); flex-direction: column; justify-content: center; 
                box-shadow: -10px 0 30px rgba(0,0,0,0.5); border-left: 1px solid var(--border);
            }
            .nav-links.active { right: 0; }
            .burger { display: flex; }
            .burger.active span:nth-child(1) { transform: rotate(45deg) translateY(13px); }
            .burger.active span:nth-child(2) { opacity: 0; }
            .burger.active span:nth-child(3) { transform: rotate(-45deg) translateY(-13px); }
        }

        /* --- ГЕРОЙ --- */
        .hero { 
            height: 100vh; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            text-align: center; 
            background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.7)), 
                        url('https://images.unsplash.com/photo-1556306535-0f09a537f0a3?q=80&w=2000'); 
            background-size: cover; 
            background-position: center; 
            background-attachment: fixed;
            padding: 0 20px; 
        }
        .hero h1 { 
            font-size: clamp(2.5rem, 10vw, 6rem); 
            line-height: 1; 
            font-weight: 900; 
            color: #fff; 
            text-transform: uppercase; 
            text-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        /* --- КАТАЛОГ ЖАНА ХОВЕР --- */
        .section { padding: 80px 5%; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 15px; }
        @media (min-width: 700px) { .grid { grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 25px; } }
        
        .p-card { background: var(--card); border-radius: 20px; padding: 12px; border: 1px solid var(--border); position: relative; }
        .p-card:hover { transform: translateY(-8px); border-color: var(--primary); box-shadow: var(--glow); }
        
        .p-img-box { width: 100%; aspect-ratio: 1/1; border-radius: 15px; overflow: hidden; margin-bottom: 12px; }
        .p-img { width: 100%; height: 100%; object-fit: cover; transition: 0.6s; }
        .p-card:hover .p-img { transform: scale(1.1); }

        .btn-add { 
            width: 100%; padding: 12px; border-radius: 12px; border: 1.5px solid var(--primary); 
            background: transparent; color: var(--text); font-weight: 800; cursor: pointer; 
            text-transform: uppercase; font-size: 0.7rem;
        }
        .btn-add:hover { background: var(--primary); color: #000; }

        /* --- ЖЕТКИРҮҮ АККОРДЕОНУ (ЖАРКЫРАГАН АНИМАЦИЯ) --- */
        .delivery-container { max-width: 800px; margin: 0 auto; }
        .region-card { 
            background: var(--card); 
            border-radius: 15px; 
            margin-bottom: 15px; 
            border: 1px solid var(--border); 
            overflow: hidden; 
            transition: 0.4s ease;
        }
        .region-card:hover { border-color: var(--primary); }
        
        /* Активдүү болгондо рамканын жаркырашы */
        .region-card.active { 
            border-color: var(--primary); 
            box-shadow: var(--glow); 
            transform: scale(1.02);
        }

        .region-header { 
            padding: 20px; 
            cursor: pointer; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            font-weight: 700; 
            font-size: 1.1rem;
        }
        .region-header i { transition: 0.4s; }
        .region-card.active .region-header i { transform: rotate(180deg); color: var(--primary); }

        .region-content { 
            max-height: 0; 
            padding: 0 20px; 
            overflow: hidden; 
            opacity: 0; 
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); 
            background: rgba(255, 255, 255, 0.02);
        }
        .region-card.active .region-content { 
            max-height: 500px; 
            padding: 20px; 
            opacity: 1; 
        }

        .district-row { 
            display: flex; 
            justify-content: space-between; 
            padding: 12px 0; 
            border-bottom: 1px solid var(--border); 
            font-size: 0.95rem; 
            transform: translateY(10px);
            transition: 0.4s;
        }
        .region-card.active .district-row { transform: translateY(0); }
        .district-row:last-child { border-bottom: none; }
        .district-row b { color: var(--primary); }

        /* --- КАРТА & ФУТЕР --- */
        .map-box { width: 100%; height: 350px; border-radius: 20px; overflow: hidden; border: 1px solid var(--border); margin-top: 30px; }
        footer { padding: 50px 5%; background: var(--card); text-align: center; border-top: 1px solid var(--border); }

        /* --- ЖИВО ЧАТ --- */
        .chat-widget { position: fixed; bottom: 25px; right: 25px; width: 60px; height: 60px; background: #25d366; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; cursor: pointer; z-index: 9999; box-shadow: 0 10px 20px rgba(0,0,0,0.3); }

        /* --- КОРЗИНА --- */
        .cart-modal { position: fixed; top: 0; right: -100%; width: 100%; max-width: 400px; height: 100vh; background: var(--bg); z-index: 20000; padding: 30px 20px; border-left: 1px solid var(--border); }
        .cart-modal.active { right: 0; }
        .badge { background: var(--primary); color: #000; border-radius: 50%; padding: 2px 6px; font-size: 11px; font-weight: 900; position: absolute; top: -8px; right: -8px; }
    </style>
</head>
<body>

    <nav>
        <div class="logo">KEPKA<span>.KG</span></div>
        <div class="nav-links" id="navLinks">
            <a href="#hero" onclick="toggleMenu()">Башкы бет</a>
            <a href="#about" onclick="toggleMenu()">Биз жөнүндө</a>
            <a href="#catalog" onclick="toggleMenu()">Товарлар</a>
            <a href="#delivery" onclick="toggleMenu()">Жеткирүү</a>
            <a href="#contact" onclick="toggleMenu()">Дарек</a>
        </div>
        <div style="display:flex; gap:15px; align-items:center;">
            <i data-lucide="sun" id="themeBtn" onclick="toggleMode()" style="cursor:pointer;"></i>
            <div onclick="toggleCart()" style="position:relative; cursor:pointer;">
                <i data-lucide="shopping-bag"></i>
                <span id="c-count" class="badge">0</span>
            </div>
            <div class="burger" id="burger" onclick="toggleMenu()">
                <span></span><span></span><span></span>
            </div>
        </div>
    </nav>

    <section class="hero" id="hero">
        <div>
            <p style="letter-spacing:8px; font-size:0.7rem; margin-bottom:15px; opacity:0.8;">PREMIUM COLLECTION 2026</p>
            <h1>ЭҢ МЫКТЫ<br><span style="color:var(--primary)">КЕПКАЛАР</span></h1>
        </div>
    </section>

    <section class="section" id="about">
        <div style="border: 1px solid var(--border); padding: 40px; border-radius: 30px; background: var(--card); position: relative;">
            <h2 style="font-size:2.2rem; margin-bottom:20px;">Биз <span>жөнүндө</span></h2>
            <p style="font-size:1.1rem; line-height:1.7; opacity:0.9;">
                <b>KEPKA_KG</b> — 2018-жылдан бери Кыргызстандын рыногунда баш кийимдердин лидери. Биздин кепкалар жогорку сапаттагы материалдардан тигилип, формасын жоготпойт. Биз ар бир кардардын табитине жараша стиль сунуштайбыз.
            </p>
            <div style="display: flex; gap: 20px; margin-top: 30px;">
                <div><h2 style="color:var(--primary)">8+</h2><p>Жыл тажрыйба</p></div>
                <div><h2 style="color:var(--primary)">10к+</h2><p>Сатылган товар</p></div>
            </div>
        </div>
    </section>

    <section class="section" id="catalog">
        <h2 style="text-align:center; font-size:2.5rem; margin-bottom:40px;">Жаңы <span>Товарлар</span></h2>
        <div class="grid" id="pGrid"></div>
    </section>

    <section class="section" id="delivery">
        <h2 style="text-align:center; font-size:2.5rem; margin-bottom:40px;">Жеткирүү <span>баалары</span></h2>
        <div class="delivery-container" id="dGrid"></div>
    </section>

    <section class="section" id="contact">
        <h2 style="text-align:center; margin-bottom:40px;">Биздин <span>Даректер</span></h2>
        <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap:20px;">
            <div style="background:var(--card); padding:25px; border-radius:20px; border:1px solid var(--border);">
                <h3>Бишкек ш.</h3>
                <p>📍 Киев көчөсү 148, ЦУМ</p>
                <p>📞 +996 770 095 809</p>
            </div>
            <div style="background:var(--card); padding:25px; border-radius:20px; border:1px solid var(--border);">
                <h3>Ош ш.</h3>
                <p>📍 "Келечек" базары</p>
                <p>📞 +996 770 095 809</p>
            </div>
        </div>
        <div class="map-box">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3000!2d72.8!3d40.5!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDDCsDMwJzAwLjAiTiA3MsKwNDgnMDAuMCJF!5e0!3m2!1sky!2skg!4v1700000000000" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
        </div>
    </section>

    <footer>
        <div class="logo">KEPKA<span>.KG</span></div>
        <p style="opacity:0.6; margin: 15px 0;">© 2026 KEPKA_KG - Стиль бул жерден башталат.</p>
        <div style="display:flex; justify-content:center; gap:20px;">
            <i data-lucide="instagram"></i>
            <i data-lucide="facebook"></i>
        </div>
    </footer>

    <div class="chat-widget" onclick="window.open('https://wa.me/996770095809?text=Саламатсызбы! Мага маалымат бересизби?')">
        <i data-lucide="message-circle" size="30"></i>
    </div>

    <div class="cart-modal" id="cartModal">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <h2>Себет</h2>
            <i data-lucide="x" onclick="toggleCart()" style="cursor:pointer;"></i>
        </div>
        <div id="cItems" style="height:65%; overflow-y:auto;"></div>
        <div style="padding-top:20px; border-top:1px solid var(--border);">
            <h3 id="tPrice" style="margin-bottom:15px; font-size:1.5rem;">Жалпы: 0 сом</h3>
            <button onclick="sendOrder()" class="btn-add" style="background:var(--primary); color:#000; font-size:1rem;">WhatsApp аркылуу заказ берүү</button>
        </div>
    </div>

    <script>
        lucide.createIcons();
        let cart = [];

        function toggleMode() {
            document.body.classList.toggle('light-mode');
            const icon = document.body.classList.contains('light-mode') ? 'moon' : 'sun';
            document.getElementById('themeBtn').setAttribute('data-lucide', icon);
            lucide.createIcons();
        }

        function toggleMenu() {
            document.getElementById('navLinks').classList.toggle('active');
            document.getElementById('burger').classList.toggle('active');
        }

        function toggleCart() { document.getElementById('cartModal').classList.toggle('active'); }

        const products = [
            {name: "Классикалык кепка", price: 1100, img: "https://images.unsplash.com/photo-1588850561407-ed78c282e89b?q=80&w=500"},
            {name: "Боз тустогу модель", price: 800, img: "https://images.unsplash.com/photo-1556306535-0f09a537f0a3?q=80&w=500"},
            {name: "Vintage", price: 1200, img: "https://images.unsplash.com/photo-1521369909029-2afed882baee?q=80&w=500"},
            {name: "Бейсболка", price: 1100, img: "https://i.pinimg.com/236x/53/8b/51/538b510b5c6457e119bd10872c27b31b.jpg"},
            {name: "Charm City", price: 800, img: "https://i.pinimg.com/originals/3f/5f/72/3f5f7211cd27cbc75df99841589cd4b4.jpg"},
            {name: "Turkey", price: 900, img: "https://img-edg.joomcdn.net/92e33f00cc13a5c032d9a97b76c27060ffe1dc48_original.jpeg"},
            {name: "Urban Cap", price: 1800, img: "https://images.unsplash.com/photo-1534215754734-18e55d13e346?q=80&w=500"},
            {name: "KUIU", price: 2100, img: "https://outgear.kg/wp-content/uploads/2025/06/7-1.jpg"},
            {name: "Огурчик кепка", price: 3500, img: "https://friendfunction.ru/upload/dev2fun.imagecompress/webp/iblock/c61/yz52nsf4efppw611k52ds2b2pme5jz7g/d5e602db21d698aa211d2dbd4a66bc4a.webp"},
            {name: "Этно кепка", price: 2400, img: "https://ethno.market/wa-data/public/shop/products/32/27/2732/images/13052/13052.750@2x.jpg"},
            {name: "THRASHER", price: 3000, img: "https://www.34play.me/loaded/catalog/goods/thumbs/8de66b5f3a584c0bb171d18e2a4e0196.jpg"},
            {name: "Worthy", price: 3000, img: "https://images.unsplash.com/photo-1589831377283-33cb1cc6bd5d?q=80&w=500"},
            {name: "Relax", price: 3200, img: "https://rybolovnyi.ru/wa-data/public/shop/products/26/14/71426/images/133464/133464.970.jpg"},
            {name: "Этно кепка", price: 1900, img: "https://images.prom.ua/5950744581_w640_h640_bejsbolka-etno-forhed.jpg"},
            {name: "TRAILHEAD", price: 3400, img: "https://www.34play.me/loaded/catalog/goods/thumbs/e1194464fbb71a10bc1a1db731ead59f.jpg"},
            {name: "TOROZ", price: 2700, img: "https://toroz.eu/wp-content/uploads/2024/03/DSC08160-scaled.jpg"},
            {name: "Красавчик", price: 1350, img: "https://www.karandash.by/image/design/11642/30.jpg"},
            {name: "Turgoyak", price: 1800, img: "https://turgoyak-sport.ru/upload/iblock/083/o16b7ah0vqgoevjxzn35sehm5nyq1fcc.jpg"},
            {name: "Достук", price: 1600, img: "https://basket-15.wbbasket.ru/vol2384/part238405/238405805/images/c516x688/1.webp"},
            {name: "Мурас", price: 2000, img: "https://i.pinimg.com/736x/84/43/e0/8443e060d09e93cd3435031ced6bcc7a.jpg"}
        ];

        const grid = document.getElementById('pGrid');
        products.forEach(p => {
            grid.innerHTML += `
                <div class="p-card">
                    <div class="p-img-box"><img src="${p.img}" class="p-img"></div>
                    <h3 style="font-size:0.9rem; margin-bottom:5px;">${p.name}</h3>
                    <p style="color:var(--primary); font-weight:800; font-size:1.1rem; margin-bottom:12px;">${p.price} сом</p>
                    <button class="btn-add" onclick="addToCart('${p.name}', ${p.price})">Кошуу</button>
                </div>`;
        });

        const regions = [
            { name: "Чүй областы", districts: ["Бишкек - 150с", "Токмок - 250с", "Кара-Балта - 300с"] },
            { name: "Ош областы", districts: ["Ош шаары - 150с", "Кара-Суу - 250с", "Өзгөн - 300с"] },
            { name: "Жалал-Абад областы", districts: ["Жалал-Абад - 300с", "Таш-Көмүр - 350с"] },
            { name: "Ысык-Көл областы", districts: ["Каракол - 350с", "Чолпон-Ата - 300с"] },
            { name: "Нарын областы", districts: ["Нарын ш. - 350с", "Кочкор - 300с"] },
            { name: "Баткен областы", districts: ["Баткен ш. - 400с", "Кызыл-Кыя - 350с"] },
            { name: "Талас областы", districts: ["Талас ш. - 300с", "Манас р. - 350с"] }
        ];

        const dGrid = document.getElementById('dGrid');
        regions.forEach(r => {
            dGrid.innerHTML += `
                <div class="region-card">
                    <div class="region-header" onclick="this.parentElement.classList.toggle('active')">
                        ${r.name} <i data-lucide="chevron-down"></i>
                    </div>
                    <div class="region-content">
                        ${r.districts.map(d => `<div class="district-row"><span>${d.split(' - ')[0]}</span><b>${d.split(' - ')[1]}</b></div>`).join('')}
                    </div>
                </div>`;
        });

        function addToCart(name, price) {
            cart.push({name, price});
            document.getElementById('c-count').innerText = cart.length;
            updateCart();
        }

        function updateCart() {
            const list = document.getElementById('cItems');
            list.innerHTML = "";
            let sum = 0;
            cart.forEach((item, index) => {
                sum += item.price;
                list.innerHTML += `<div style="display:flex; justify-content:space-between; padding:10px; background:var(--card); margin-bottom:8px; border-radius:10px;">
                    <span>${item.name}</span><b>${item.price} с</b>
                </div>`;
            });
            document.getElementById('tPrice').innerText = `Жалпы: ${sum} сом`;
        }

        function sendOrder() {
            if(cart.length === 0) return alert("Себет бош!");
            let msg = "Саламатсызбы, KEPKA_KG! Мен ушул товарларды заказ кылам:\n" + cart.map(i => `- ${i.name}`).join("\n") + `\n\n${document.getElementById('tPrice').innerText}`;
            window.open(`https://wa.me/996770095809?text=${encodeURIComponent(msg)}`);
        }
    </script>
</body>
</html>
